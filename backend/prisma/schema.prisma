
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum HabitFrequency {
  DAILY
  EVERYOTHERDAY
  EVERYTHREEDAY
  WEEKLY
  MONTHL
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  name            String          
  passwordHash    String

  habits          Habit[]
  refreshTokens   RefreshToken[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model RefreshToken {
  id          String   @id @default(cuid())
  token       String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  userAgent   String?
  ipAddress   String? 
  
  // Security and Tracking
  isRevoked   Boolean  @default(false)
  replacedBy  String?  // token rotation
  
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt 

  @@index([userId])
  @@index([expiresAt])
}

model Habit {
  id              String          @id @default(cuid())    
  name            String        
  status          Boolean         @default(true)
  frequency       HabitFrequency

  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  habitLogs       HabitLog[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model HabitLog {
  id              String          @id @default(cuid())   
  isCompleted     Boolean         @default(false)

  habitId         String
  habit           Habit           @relation(fields: [habitId], references: [id], onDelete: Cascade)

  entryDate       DateTime        @default(now()) @db.Date
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([habitId, entryDate])
}